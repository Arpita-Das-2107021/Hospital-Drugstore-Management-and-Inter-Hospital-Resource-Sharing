"""
Hospital Registration Models for Healthcare Resource Sharing Platform

These models handle the registration of new hospitals joining the platform,
including API configuration and admin user management.
"""

import uuid
from django.db import models
from django.contrib.auth.models import AbstractUser
from django.core.validators import RegexValidator
from django.utils import timezone


class Hospital(models.Model):
    """
    Model representing a hospital registering on the platform
    """
    
    STATUS_CHOICES = [
        ('PENDING_VERIFICATION', 'Pending Verification'),
        ('ACTIVE', 'Active'),
        ('API_FAILED', 'API Failed'),
    ]
    
    id = models.UUIDField(primary_key=True, default=uuid.uuid4, editable=False)
    hospital_name = models.CharField(max_length=255, help_text="Official name of the hospital")
    license_number = models.CharField(
        max_length=100, 
        unique=True,
        help_text="Hospital license number for verification"
    )
    address = models.TextField(help_text="Full address of the hospital")
    city = models.CharField(max_length=100)
    country = models.CharField(max_length=100, default="Bangladesh")
    contact_email = models.EmailField(
        unique=True,
        help_text="Primary contact email for hospital communications"
    )
    
    # Phone number validation
    phone_regex = RegexValidator(
        regex=r'^\+?1?\d{9,15}$',
        message="Phone number must be entered in the format: '+999999999'. Up to 15 digits allowed."
    )
    contact_phone = models.CharField(
        validators=[phone_regex], 
        max_length=17, 
        help_text="Contact phone number"
    )
    
    status = models.CharField(
        max_length=20,
        choices=STATUS_CHOICES,
        default='PENDING_VERIFICATION',
        help_text="Current status of hospital registration"
    )
    
    created_at = models.DateTimeField(auto_now_add=True)
    updated_at = models.DateTimeField(auto_now=True)
    
    # Additional metadata
    verification_notes = models.TextField(
        blank=True,
        help_text="Notes added during verification process"
    )
    verified_at = models.DateTimeField(
        null=True, 
        blank=True,
        help_text="Timestamp when hospital was verified"
    )
    verified_by = models.ForeignKey(
        'HospitalUser',
        on_delete=models.SET_NULL,
        null=True,
        blank=True,
        related_name='verified_hospitals',
        help_text="Admin who verified this hospital"
    )
    
    class Meta:
        verbose_name = "Hospital"
        verbose_name_plural = "Hospitals"
        ordering = ['-created_at']
        indexes = [
            models.Index(fields=['status']),
            models.Index(fields=['city', 'country']),
            models.Index(fields=['created_at']),
        ]
    
    def __str__(self):
        return f"{self.hospital_name} ({self.city})"
    
    def is_active(self):
        """Check if hospital is in active status"""
        return self.status == 'ACTIVE'
    
    def mark_as_verified(self, verified_by_user=None):
        """Mark hospital as verified and active"""
        self.status = 'ACTIVE'
        self.verified_at = timezone.now()
        if verified_by_user:
            self.verified_by = verified_by_user
        self.save()


class HospitalAPIConfig(models.Model):
    """
    Configuration for hospital's API integration
    Stores connection details and endpoints for resource sharing
    """
    
    AUTH_TYPE_CHOICES = [
        ('API_KEY', 'API Key'),
        ('BEARER', 'Bearer Token'),
    ]
    
    CONNECTION_STATUS_CHOICES = [
        ('UNTESTED', 'Untested'),
        ('CONNECTED', 'Connected'),
        ('FAILED', 'Failed'),
        ('TIMEOUT', 'Timeout'),
    ]
    
    hospital = models.OneToOneField(
        Hospital,
        on_delete=models.CASCADE,
        related_name='api_config',
        help_text="Hospital this configuration belongs to"
    )
    
    # API Connection Details
    api_base_url = models.URLField(
        help_text="Base URL for hospital's API (e.g., https://api.hospital.com/v1/)"
    )
    auth_type = models.CharField(
        max_length=10,
        choices=AUTH_TYPE_CHOICES,
        default='API_KEY',
        help_text="Authentication method used by the hospital API"
    )
    api_key = models.CharField(
        max_length=500,
        help_text="API key or token for authentication"
    )
    
    # API Endpoints
    inventory_endpoint = models.CharField(
        max_length=200,
        default='/inventory',
        help_text="Endpoint for inventory data (relative to base URL)"
    )
    staff_endpoint = models.CharField(
        max_length=200,
        default='/staff',
        help_text="Endpoint for staff data (relative to base URL)"
    )
    transfer_request_endpoint = models.CharField(
        max_length=200,
        default='/transfers',
        help_text="Endpoint for transfer requests (relative to base URL)"
    )
    
    # Connection Monitoring
    connection_status = models.CharField(
        max_length=15,
        choices=CONNECTION_STATUS_CHOICES,
        default='UNTESTED',
        help_text="Current status of API connection"
    )
    last_checked_at = models.DateTimeField(
        null=True,
        blank=True,
        help_text="Last time API connection was tested"
    )
    
    # Configuration metadata
    created_at = models.DateTimeField(auto_now_add=True)
    updated_at = models.DateTimeField(auto_now=True)
    
    # Additional settings
    timeout_seconds = models.PositiveIntegerField(
        default=30,
        help_text="Request timeout in seconds"
    )
    retry_attempts = models.PositiveIntegerField(
        default=3,
        help_text="Number of retry attempts for failed requests"
    )
    is_active = models.BooleanField(
        default=True,
        help_text="Whether this API configuration is active"
    )
    
    class Meta:
        verbose_name = "Hospital API Configuration"
        verbose_name_plural = "Hospital API Configurations"
        ordering = ['-created_at']
    
    def __str__(self):
        return f"API Config for {self.hospital.hospital_name}"
    
    def get_full_inventory_url(self):
        """Get complete URL for inventory endpoint"""
        return f"{self.api_base_url.rstrip('/')}{self.inventory_endpoint}"
    
    def get_full_staff_url(self):
        """Get complete URL for staff endpoint"""
        return f"{self.api_base_url.rstrip('/')}{self.staff_endpoint}"
    
    def get_full_transfer_url(self):
        """Get complete URL for transfer endpoint"""
        return f"{self.api_base_url.rstrip('/')}{self.transfer_request_endpoint}"
    
    def test_connection(self):
        """Test API connection and update status"""
        # This method could be implemented to actually test the API connection
        # For now, it's a placeholder
        import requests
        try:
            response = requests.get(
                self.get_full_inventory_url(),
                headers=self.get_auth_headers(),
                timeout=self.timeout_seconds
            )
            if response.status_code == 200:
                self.connection_status = 'CONNECTED'
            else:
                self.connection_status = 'FAILED'
        except requests.exceptions.Timeout:
            self.connection_status = 'TIMEOUT'
        except requests.exceptions.RequestException:
            self.connection_status = 'FAILED'
        
        self.last_checked_at = timezone.now()
        self.save()
        return self.connection_status
    
    def get_auth_headers(self):
        """Get authentication headers for API requests"""
        if self.auth_type == 'API_KEY':
            return {'X-API-Key': self.api_key}
        elif self.auth_type == 'BEARER':
            return {'Authorization': f'Bearer {self.api_key}'}
        return {}


class HospitalUser(AbstractUser):
    """
    Extended User model for hospital administrators
    Inherits from AbstractUser and adds hospital-specific fields
    """
    
    ROLE_CHOICES = [
        ('HOSPITAL_ADMIN', 'Hospital Administrator'),
        ('PLATFORM_ADMIN', 'Platform Administrator'),
        ('STAFF_MEMBER', 'Staff Member'),
    ]
    
    role = models.CharField(
        max_length=20,
        choices=ROLE_CHOICES,
        default='HOSPITAL_ADMIN',
        help_text="User's role in the system"
    )
    
    hospital = models.ForeignKey(
        Hospital,
        on_delete=models.CASCADE,
        null=True,
        blank=True,
        related_name='users',
        help_text="Hospital this user is associated with (null for platform admins)"
    )
    
    # Additional user information
    phone_number = models.CharField(
        max_length=17,
        blank=True,
        validators=[Hospital.phone_regex],
        help_text="User's contact phone number"
    )
    job_title = models.CharField(
        max_length=100,
        blank=True,
        help_text="User's job title at the hospital"
    )
    
    # Account metadata
    is_verified = models.BooleanField(
        default=False,
        help_text="Whether user's email has been verified"
    )
    created_at = models.DateTimeField(auto_now_add=True)
    updated_at = models.DateTimeField(auto_now=True)
    
    # Required fields for AbstractUser
    USERNAME_FIELD = 'username'
    REQUIRED_FIELDS = ['email', 'first_name', 'last_name']
    
    class Meta:
        verbose_name = "Hospital User"
        verbose_name_plural = "Hospital Users"
        ordering = ['-created_at']
        indexes = [
            models.Index(fields=['role']),
            models.Index(fields=['hospital', 'role']),
            models.Index(fields=['is_verified']),
        ]
    
    def __str__(self):
        if self.hospital:
            return f"{self.get_full_name()} ({self.hospital.hospital_name})"
        return f"{self.get_full_name()} ({self.get_role_display()})"
    
    def is_hospital_admin(self):
        """Check if user is a hospital administrator"""
        return self.role == 'HOSPITAL_ADMIN'
    
    def is_platform_admin(self):
        """Check if user is a platform administrator"""
        return self.role == 'PLATFORM_ADMIN'
    
    def can_manage_hospital(self, hospital):
        """Check if user can manage a specific hospital"""
        if self.is_platform_admin():
            return True
        if self.is_hospital_admin() and self.hospital == hospital:
            return True
        return False
    
    def get_full_name(self):
        """Get full name from related User model"""
        return self.user.get_full_name()


class RegistrationLog(models.Model):
    """
    Log model for tracking hospital registration events
    """
    
    ACTION_CHOICES = [
        ('REGISTRATION_STARTED', 'Registration Started'),
        ('REGISTRATION_COMPLETED', 'Registration Completed'),
        ('VERIFICATION_STARTED', 'Verification Started'),
        ('VERIFICATION_COMPLETED', 'Verification Completed'),
        ('STATUS_CHANGED', 'Status Changed'),
        ('API_CONFIG_UPDATED', 'API Configuration Updated'),
        ('ERROR_OCCURRED', 'Error Occurred'),
    ]
    
    hospital = models.ForeignKey(
        Hospital,
        on_delete=models.CASCADE,
        related_name='registration_logs',
        help_text="Hospital this log entry is for"
    )
    
    action = models.CharField(
        max_length=25,
        choices=ACTION_CHOICES,
        help_text="Type of action that occurred"
    )
    
    description = models.TextField(
        help_text="Detailed description of the action"
    )
    
    user = models.ForeignKey(
        HospitalUser,
        on_delete=models.SET_NULL,
        null=True,
        blank=True,
        help_text="User who performed the action (if applicable)"
    )
    
    ip_address = models.GenericIPAddressField(
        null=True,
        blank=True,
        help_text="IP address from which the action was performed"
    )
    
    metadata = models.JSONField(
        default=dict,
        blank=True,
        help_text="Additional metadata about the action"
    )
    
    created_at = models.DateTimeField(auto_now_add=True)
    
    class Meta:
        verbose_name = "Registration Log"
        verbose_name_plural = "Registration Logs"
        ordering = ['-created_at']
        indexes = [
            models.Index(fields=['hospital', 'action']),
            models.Index(fields=['created_at']),
        ]
    
    def __str__(self):
        return f"{self.hospital.hospital_name} - {self.get_action_display()}"